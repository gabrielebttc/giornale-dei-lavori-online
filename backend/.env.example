# ─── Database ───────────────────────────────────────────────
# In locale usa localhost, in Docker usa il nome del container (db)
DATABASE_URL=postgres://your_db_user:your_db_password@localhost:5432/your_db_name

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_long_random_string
JWT_REFRESH_SECRET=your_jwt_refresh_secret_long_random_string
ACCESS_TOKEN_EXPIRY=2h
REFRESH_TOKEN_EXPIRY=30d
REFRESH_TOKEN_EXPIRY_DAYS=30

# ─── Google OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://tuodominio.com/api/google/auth/google

# ─── Collabora Online ────────────────────────────────────────
# URL di Collabora accessibile dal browser (in Docker: http://localhost:9980)
COLLABORA_URL=http://localhost:9980
# URL del backend raggiungibile dal container Collabora per WOPI (in Docker: http://backend:3001)
WOPI_BASE_URL=http://localhost:3001

# ─── Backblaze B2 ────────────────────────────────────────────
BACKBLAZE_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
BACKBLAZE_REGION=eu-central-003
BACKBLAZE_ACCESS_KEY_ID=your_backblaze_key_id
BACKBLAZE_SECRET_ACCESS_KEY=your_backblaze_secret_key
BACKBLAZE_BUCKET_NAME=your_bucket_name
