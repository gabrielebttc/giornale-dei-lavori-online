# ─── Database ───────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=estelle
POSTGRES_DB=libretto_del_lavoro_db

# URL usato dal backend per connettersi al db (il host è "db" = nome del container)
DATABASE_URL=postgres://postgres:estelle@db:5432/libretto_del_lavoro_db

# ─── Backend URL ────────────────────────────────────────────
# URL del backend esposto al frontend (in produzione: dominio pubblico)
FRONTEND_BACKEND_URL=https://giornaledeilavori.gabrielebuttice.com
